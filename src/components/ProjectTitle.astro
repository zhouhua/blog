---
import { cn } from '@lib/utils';

interface Props {
  title: string;
  description?: string;
}

const { description, title } = Astro.props;
---

<style>
@reference '../styles/global.css';

.Header {
  margin: 80px auto 50px;
  width: 100%;
  max-width: 450px;
  padding: 0 20px;
  @media (width >= 40rem) {
    margin: 100px auto 70px;
    padding-inline: 0;
  }
  @media (width >= 48rem) {
    max-width: 560px;
    padding-left: 53px;
  }
  @media (width >= 64rem) {
    margin: 100px auto 120px;
    max-width: 749px;
    padding-left: 68px;
  }
  @media screen and (max-height: 700px) {
    margin: 50px auto;
  }
}
.HeroHeading {
}
</style>

<header class={cn('Header', 'relative z-10')}>
  <h1
    class={cn(
      'colorModeTransition font-sans font-bold text-primary mb-5 wrap-break-word text-[36px] leading-[1.3]',
      'sm:text-[38px] md:text-[42px] lg:mb-[25px] lg:text-[48px] lg:leading-[1.32]',
    )}
  >
    {title}
  </h1>
  {description && (
    <div class="mt-3 flex items-center leading-6 text-secondary/80 sm:mt-4">
      <span class="mr-2 iconify maki--information" />
      {description}
    </div>
  )}
</header>
