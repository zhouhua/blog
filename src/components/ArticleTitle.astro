---
import { cn } from '@lib/utils';
import FormatDate from '@react/components/FormatDate';
import { Badge } from '@react/ui/badge';
import Author from './Author.astro';

interface Props {
  title: string;
  time: Date | number;
  tags?: string[];
  isJournal?: boolean;
}

const TAG_SLUG_RE = /\s+|\//g;
const { isJournal = false, tags = [], time, title } = Astro.props;

---

<style>
@reference '../styles/global.css';

.Header {
  margin: 80px auto 50px;
  width: 100%;
  max-width: 450px;
  padding: 0 20px;
  @media (width >= 40rem) {
    margin: 100px auto 70px;
    padding-inline: 0;
  }
  @media (width >= 48rem) {
    max-width: 560px;
    padding-left: 53px;
  }
  @media (width >= 64rem) {
    margin: 100px auto 120px;
    max-width: 749px;
    padding-left: 68px;
  }
  @media screen and (max-height: 700px) {
    margin: 50px auto;
  }
}
</style>

<header class={cn('Header', 'relative z-10')}>
  <h1
    class={cn(
      'colorModeTransition font-sans font-bold text-primary mb-5 wrap-break-word text-[36px] leading-[1.3]',
      'sm:text-[38px] md:text-[42px] lg:mb-[25px] lg:text-[48px] lg:leading-[1.32]',
    )}
  >
    {title}
  </h1>
  <div
    class={cn(
      'colorModeTransition relative flex w-full flex-col gap-2 text-sm text-gray',
      'sm:flex-row sm:items-center sm:justify-between sm:text-lg',
    )}
  >
    <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:gap-0">
      <Author />
      <div>
        <FormatDate client:only="react" time={time} />
        &bull;
        <slot />
      </div>
    </div>
    {isJournal && (
      <a
        class="mt-2 self-start underline-offset-4 hover:text-accent hover:underline sm:mt-0"
        href="/journals"
      >
        更多随笔
      </a>
    )}
  </div>
  {tags.length > 0 && (
    <div class="mb-4 mt-6 flex flex-wrap gap-3 sm:mt-8 sm:gap-4">
    {
      tags.map(tag => (
        <a href={`/tag/${tag.replace(TAG_SLUG_RE, '-').toLowerCase()}`}>
          <Badge className="text-sm font-monospace border-secondary/80" variant="outline">
          <span
            class="mr-1 h-3 w-3 text-accent opacity-80 heroicons--hashtag-solid iconify"
          />
          {tag}
          </Badge>
        </a>
      ))
    }
    </div>
  )}
</header>
