---
import type { CollectionEntry } from 'astro:content';
import { cn } from '@lib/utils';
import EvervaultCard from '@react/components/EvervaultCard';
import ListItem from './ArticleListItem.astro';

interface Props {
  posts: [CollectionEntry<'blog'>, CollectionEntry<'blog'>] | [CollectionEntry<'blog'>];
  gridLayout: 'rows' | 'tiles';
  reverse?: boolean;
  showAllLink?: boolean;
}

const { gridLayout, posts, reverse = false, showAllLink } = Astro.props;
const displayPosts = reverse ? posts.slice(0, 2).toReversed() : posts.slice(0, 2);
const pairClassName = gridLayout === 'tiles'
  ? cn(
    'relative grid grid-cols-1 gap-y-10 sm:gap-x-6',
    reverse
      ? 'sm:grid-cols-2 lg:grid-cols-[457px_minmax(0,_1fr)] mb-10'
      : 'sm:grid-cols-2 lg:grid-cols-[minmax(0,_1fr)_457px] mb-10',
  )
  : cn('grid grid-cols-1 gap-y-10', {
    'grid-rows-1': posts.length === 1,
    'grid-rows-2': posts.length > 1,
  });
---

<style>
@reference '../styles/global.css';

.moreLink {
  border-radius: 5px;
  box-shadow: 0px 20px 40px rgba(0, 0, 0, 0.2);
  @media (width >= 40rem) {
    box-shadow: none;
  }
}
</style>

<div class={pairClassName}>
      {displayPosts.map((article, i) => (
        <ListItem
          gridLayout={gridLayout}
          narrow={gridLayout === 'tiles' && (reverse ? i === 0 : i === 1)}
          post={article}
        />
      ))}
      {showAllLink && (
        <a
          class={cn(
            'moreLink',
            'flex items-center justify-center rounded-2xl bg-card',
          )}
          href="/articles"
        >
          <EvervaultCard className="sm:h-full h-[430px]" client:only="react" text="查看所有文章" />
        </a>
      )}
</div>
