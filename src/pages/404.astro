---
import Container from '@components/Container.astro';
import { HOME } from '@consts';
import PageLayout from '@layouts/PageLayout.astro';
import { Button } from '@react/ui/button';

---
<style>
@reference '../styles/global.css';

.text {
  color: var(--primary);
  position: relative;
  font-family: var(--font-monospace);
  line-height: 1;
  height: 320px;
  font-size: 320px;
  transition:
    background 0.25s var(--ease-in-out-quad),
    border 0.25s var(--ease-in-out-quad),
    color 0.25s var(--ease-in-out-quad);
}
.white {
  background-color: transparent;
  position: absolute;
  left: -10px;
  right: -10px;
  z-index: 4;
  height: 8px;
  animation: whiteMove 3s ease-out infinite;
  transition:
    border 0.25s var(--ease-in-out-quad),
    color 0.25s var(--ease-in-out-quad);
}

@media (min-width: 40rem) {
  .text {
    height: 200px;
    font-size: 200px;
  }

  .white {
    height: 4px;
  }
  .text::after {
    left: -8px;
  }
}

@media (min-width: 48rem) {
  .text {
    height: 280px;
    font-size: 280px;
  }
}

.text::before {
  color: color-mix(in oklch, var(--primary) 90%, transparent);
  position: absolute;
  left: 4px;
  top: 0;
  z-index: 2;
  height: 0;
  overflow: hidden;
  content: attr(data-text);
  animation: redShadow 1s ease-in infinite;
  filter: contrast(200%);
  text-shadow: 1px 0 0 red;
  transition:
    background 0.25s var(--ease-in-out-quad),
    border 0.25s var(--ease-in-out-quad),
    color 0.25s var(--ease-in-out-quad);
}

.text::after {
  background-color: color-mix(in oklch, var(--color-bg) 90%, transparent);
  color: color-mix(in oklch, var(--primary) 80%, transparent);
  position: absolute;
  left: -12px;
  top: 0;
  z-index: 3;
  height: 100%;
  overflow: hidden;
  content: attr(data-text);
  animation: redHeight 1.5s ease-out infinite;
  filter: contrast(200%);
  text-shadow: -1px 0 0 cyan;
  mix-blend-mode: darken;
  transition:
    background 0.25s var(--ease-in-out-quad),
    border 0.25s var(--ease-in-out-quad),
    color 0.25s var(--ease-in-out-quad);
}
:global(.dark) .text::after {
  mix-blend-mode: lighten;
}

@keyframes redShadow {
  20% {
    height: 88.89%;
  }
  60% {
    height: 16.67%;
  }
  100% {
    height: 116.67%;
  }
}

@keyframes redHeight {
  20% {
    height: 116.67%;
  }
  35% {
    height: 33.33%;
  }
  50% {
    height: 11.11%;
  }
  60% {
    height: 5.56%;
  }
  70% {
    height: 94.44%;
  }
  80% {
    height: 61.11%;
  }
  100% {
    height: 0;
  }
}

@keyframes whiteMove {
  8% {
    top: 105.56%;
  }
  14% {
    top: 22.22%;
  }
  20% {
    top: 116.67%;
  }
  32% {
    top: 5.56%;
  }
  99% {
    top: 83.33%;
  }
}
</style>

<PageLayout description={HOME.DESCRIPTION} title={HOME.TITLE}>
  <Container>
    <div class="flex w-full items-center justify-center">
      <div class="text" data-text="404">
        404
        <div class="white" />
      </div>
    </div>
    <h1 class="mt-20 text-center text-lg">找不到你访问的页面</h1>
    <div class="flex justify-center pt-10">
      <a href="/" class="cursor-pointer">
        <Button variant="link">
          回到首页
        </Button>
      </a>
    </div>
  </Container>
</PageLayout>
