---
import Container from '@components/Container.astro';
import ListTitle from '@components/ListTitle.astro';
import { JOURNALS } from '@consts';
import PageLayout from '@layouts/PageLayout.astro';
import { getReadInfo } from '@lib/html';
import JournalList from '@react/components/JournalList';
import { getCollection } from 'astro:content';
import dayjs from 'dayjs';

const data = (await getCollection('journals')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const items = data.map((item) => {
  const year = item.data.date.getFullYear();
  const dateString = dayjs(item.data.date).format('MM-DD');
  const body = item.body || '';
  const { timeToRead, wordCount } = getReadInfo(body);
  return {
    dateString,
    html: item.rendered?.html ?? '',
    timeToRead,
    wordCount,
    year,
  };
});
---

<PageLayout description={JOURNALS.DESCRIPTION} title={JOURNALS.TITLE}>
  <ListTitle
    description="随手记录不成熟的想法"
    title="周骅的博客 - 所有随笔"
  />
  <Container>
    <JournalList client:only="react" items={items} />
  </Container>
</PageLayout>
