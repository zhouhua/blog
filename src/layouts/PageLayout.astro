---
import Footer from '@components/Footer.astro';
import Head from '@components/Head.astro';
import Header from '@components/Header.astro';
import { SITE } from '@consts';
import 'katex/dist/katex.css';

type Props = {
  title: string;
  description: string;
};

const { description, title } = Astro.props;
---

<!doctype html>
<html lang="zh-Hans">
  <head>
    <Head description={description} title={title ? `${title} | ${SITE.NAME}` : SITE.NAME} />
  </head>
  <body class="colorModeTransition relative h-screen overflow-y-auto scrollbar-both-edges bg-bg">
    <div class="bg-bg text-foreground" data-vaul-drawer-wrapper>
      <Header />
      <main transition:animate="slide">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>

<script>
import mediumZoom from 'medium-zoom/dist/pure';
import { annotate } from 'rough-notation';
import 'medium-zoom/dist/style.css';

async function initPageEffect() {
  const callouts = document.querySelectorAll<HTMLDivElement>('article .callout');
  callouts.forEach(callout =>
    annotate(callout, {
      animate: false,
      color: 'var(--color-bgAlt)',
      padding: 0,
      strokeWidth: 1,
      type: 'box',
    }).show());

  const blockquates = document.querySelectorAll<HTMLDivElement>('article blockquote');
  blockquates.forEach(blockquote =>
    annotate(blockquote, {
      animate: false,
      brackets: ['left'],
      color: 'var(--color-bgAlt)',
      padding: 2,
      strokeWidth: 2,
      type: 'bracket',
    }).show());

  const limitOuterType = ['.article-columns', 'table', '.callout', 'blockquote', 'li', 'dd'];
  const limitOuterSelector = limitOuterType.map(type => `.article ${type}`).join(',');
  const picturesComtainers = document.querySelectorAll<HTMLImageElement>('article p > img');
  picturesComtainers.forEach((item) => {
    const limitOuter = item.closest(limitOuterSelector);
    if (limitOuter) {
      return;
    }
    const width = item.getAttribute('width');
    const isWide = width && +width >= 1500;
    if (isWide) {
      item.parentElement!.classList.add('fullImage');
    }
  });
  const images = document.querySelectorAll<HTMLImageElement>('article p > img:not(.zoomed)');
  images.forEach(img => img.classList.add('zoomed'));
  mediumZoom(images, {
    background: 'color-mix(in oklch, var(--color-bg) 50%, transparent)',
  });

  const mermaidElements = document.querySelectorAll<HTMLDivElement>('[data-language=mermaid]:not(.hidden)');
  if (mermaidElements.length > 0) {
    const { default: mermaid } = await import('mermaid');
    mermaid.initialize({ startOnLoad: false });
    mermaidElements.forEach(async (item, i) => {
      const code = item.textContent!;
      const { svg } = await mermaid.render(`mermaid${i}`, code);
      item.classList.add('hidden');
      item.insertAdjacentHTML('afterend', `<p>${svg}</p>`);
    });
  }

  // Copy buttons for code blocks
  document.querySelectorAll<HTMLElement>('article pre[data-language]').forEach((pre) => {
    if (pre.querySelector('.copy-code-btn'))
      return;
    const btn = document.createElement('button');
    btn.className = 'copy-code-btn';
    btn.setAttribute('aria-label', '复制代码');
    btn.innerHTML = `
      <span class="copy-icon" aria-hidden="true">
        <svg viewBox="0 0 20 20" focusable="false" aria-hidden="true">
          <rect x="6" y="4" width="10" height="12" rx="2" ry="2" class="copy-icon-front" />
          <rect x="3" y="7" width="10" height="12" rx="2" ry="2" class="copy-icon-back" />
          <path d="M6 11.5 9 14.5 14 9.5" class="copy-icon-check" />
        </svg>
      </span>
      <span class="copy-label">复制</span>
    `;
    btn.addEventListener('click', async () => {
      const code = pre.querySelector('code')?.textContent ?? '';
      await navigator.clipboard.writeText(code);
      btn.classList.add('copied');
      const label = btn.querySelector<HTMLElement>('.copy-label');
      if (label)
        label.textContent = '已复制';
      setTimeout(() => {
        btn.classList.remove('copied');
        label && (label.textContent = '复制');
      }, 2000);
    });
    pre.appendChild(btn);
  });
}

document.addEventListener('astro:page-load', initPageEffect, { once: false });
</script>
